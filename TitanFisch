local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Tintan Fisch",
   LoadingTitle = "Load",
   LoadingSubtitle = "by JICEO",
   ConfigurationSaving = {Enabled = true, FolderName = "ReyFile_Configs", FileName = "MainConfig"},
   KeySystem = false
})

local vim = game:GetService("VirtualInputManager")
local player = game.Players.LocalPlayer
local flags = {autoZ = false, autoX = false, autoC = false, autoV = false, autoCast = false, autoSell = false, autoEquip = false, autoReturn = false}

local sellPosition = Vector3.new(170.08, 23.4, 72.58)
local farmPosition = nil 
local sellDelay = 100 
_G.IsSelling = false

-- 1. CHỨC NĂNG ẨN: INSTANT E
local function makePromptsInstant()
    for _, prompt in pairs(game:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then prompt.HoldDuration = 0 end
    end
    game.DescendantAdded:Connect(function(obj)
        if obj:IsA("ProximityPrompt") then obj.HoldDuration = 0 end
    end)
end
makePromptsInstant()

-- 2. HÀM KIỂM TRA ĐANG CÂU
local function isFishing()
    local gui = player.PlayerGui
    local reelGui = gui:FindFirstChild("ReelGUI") or gui:FindFirstChild("FishingGui")
    if reelGui and reelGui.Enabled then
        return true
    end
    return false
end

-- 3. HÀM CLICK ÉP BUỘC
local function forceClick(button)
    if not button then return end
    pcall(function()
        if firesignal then firesignal(button.MouseButton1Click) end
        local pos = button.AbsolutePosition
        local size = button.AbsoluteSize
        vim:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 58, 0, true, game, 0)
        task.wait(0.05)
        vim:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 58, 0, false, game, 0)
    end)
end

-- 4. HÀM DỊCH CHUYỂN
local function instantTP(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local target = (typeof(pos) == "Vector3" and CFrame.new(pos) or pos)
        char.HumanoidRootPart.CFrame = target
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end

-- [TAB AUTO PHÍM Z/X/C/V]
local AutoTab = Window:CreateTab("Auto Phím", 4483345998)
local function startLoop(keyCode, flagName)
    task.spawn(function()
        while flags[flagName] do
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.05)
            vim:SendKeyEvent(false, keyCode, false, game)
            task.wait(0.1)
        end
    end)
end
AutoTab:CreateToggle({Name = "🚀 Auto Z", CurrentValue = false, Flag = "TZ", Callback = function(V) flags.autoZ = V if V then startLoop(Enum.KeyCode.Z, "autoZ") end end})
AutoTab:CreateToggle({Name = "⚡ Auto X", CurrentValue = false, Flag = "TX", Callback = function(V) flags.autoX = V if V then startLoop(Enum.KeyCode.X, "autoX") end end})
AutoTab:CreateToggle({Name = "🟢 Auto C", CurrentValue = false, Flag = "TC", Callback = function(V) flags.autoC = V if V then startLoop(Enum.KeyCode.C, "autoC") end end})
AutoTab:CreateToggle({Name = "🔵 Auto V", CurrentValue = false, Flag = "TV", Callback = function(V) flags.autoV = V if V then startLoop(Enum.KeyCode.V, "autoV") end end})

-- [TAB TITAN FISCH]
local FischTab = Window:CreateTab("Titan Fisch", 7072742186)

FischTab:CreateButton({
   Name = "🚩 SET TỌA ĐỘ FARM",
   Callback = function()
      if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
          farmPosition = player.Character.HumanoidRootPart.CFrame
          Rayfield:Notify({Title = "OK", Content = "Đã lưu tọa độ câu!", Duration = 2})
      end
   end,
})

FischTab:CreateToggle({
   Name = "🏠 Auto Return Point",
   CurrentValue = false,
   Flag = "RetP",
   Callback = function(V)
      flags.autoReturn = V
      if V then task.spawn(function()
         while flags.autoReturn do
            if farmPosition and not _G.IsSelling then
               local hrp = player.Character.HumanoidRootPart
               if (hrp.Position - farmPosition.Position).Magnitude > 6 then instantTP(farmPosition) end
            end
            task.wait(1)
         end
      end) end
   end,
})

FischTab:CreateToggle({
   Name = "🎒 Auto Equip Tool 1",
   CurrentValue = false,
   Flag = "AutoEq",
   Callback = function(V) 
      flags.autoEquip = V 
      if V then task.spawn(function() while flags.autoEquip do if not _G.IsSelling then
         local char = player.Character
         if char and not char:FindFirstChildOfClass("Tool") then
            local tool = player.Backpack:FindFirstChildOfClass("Tool")
            if tool then char.Humanoid:EquipTool(tool) end
         end
      end task.wait(1) end end) end
   end,
})

FischTab:CreateSection("💰 SMART AUTO SELL (100s)")

FischTab:CreateToggle({
   Name = "💵 BẬT AUTO SELL (GIỮ CẦN TRÊN TAY)",
   CurrentValue = false,
   Flag = "ToggleSell",
   Callback = function(Value)
      flags.autoSell = Value
      if Value then task.spawn(function()
         while flags.autoSell do
            task.wait(sellDelay) -- Chờ 100s
            
            while isFishing() and flags.autoSell do task.wait(1) end -- Đợi câu xong

            if not farmPosition or not flags.autoSell then continue end
            
            _G.IsSelling = true
            -- Đã bỏ lệnh UnequipTools tại đây
            task.wait(0.2)
            
            instantTP(sellPosition)
            task.wait(1.5)
            
            local sellGui = player.PlayerGui:WaitForChild("SellGUI")
            local retry = 0
            while flags.autoSell and not sellGui.Enabled and retry < 20 do
               vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
               task.wait(0.1)
               vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
               task.wait(0.4)
               retry = retry + 1
            end
            
            if sellGui.Enabled then
               task.wait(0.5)
               forceClick(sellGui.Canvas.Main:FindFirstChild("All"))
               task.wait(1)
               forceClick(sellGui.Canvas.Main:FindFirstChild("Đóng"))
               task.wait(0.5)
            end
            
            instantTP(farmPosition)
            _G.IsSelling = false
         end
      end) end
   end,
})

FischTab:CreateToggle({
   Name = "🎣 Auto Thả Cần",
   CurrentValue = false,
   Flag = "AutoCast",
   Callback = function(Value)
      flags.autoCast = Value
      if Value then task.spawn(function()
         while flags.autoCast do
            if not _G.IsSelling and player.Character:FindFirstChildOfClass("Tool") then
               vim:SendMouseButtonEvent(500, 500, 0, true, game, 0)
               task.wait(1)
               vim:SendMouseButtonEvent(500, 500, 0, false, game, 0)
            end
            task.wait(1.5)
         end
      end) end
   end,
})

Rayfield:LoadConfiguration()
