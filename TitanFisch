local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "ReyFile | FULL AUTO & SAVE",
   LoadingTitle = "Đang tải cấu hình...",
   LoadingSubtitle = "by Gemini (Fix Auto Sell)",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "ReyFile_Configs",
      FileName = "MainConfig"
   },
   KeySystem = false
})

local vim = game:GetService("VirtualInputManager")
local player = game.Players.LocalPlayer

-- Khởi tạo biến trạng thái
local flags = {
    autoZ = false,
    autoX = false,
    autoC = false,
    autoD = false,
    autoCast = false,
    autoSlot1Smart = false,
    autoSell = false -- Biến trạng thái mới cho Sell
}

-- TAB AUTO PHÍM
local AutoTab = Window:CreateTab("Auto Phím", 4483345998)
AutoTab:CreateSection("🔥 Spam phím full (Z/X/C/D)")

local function startLoop(keyCode, flagName)
    task.spawn(function()
        while flags[flagName] do
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(math.random(3, 7) / 100)
            vim:SendKeyEvent(false, keyCode, false, game)
            task.wait(math.random(10, 18) / 100)
        end
    end)
end

AutoTab:CreateToggle({
   Name = "🚀 Auto Z",
   CurrentValue = false,
   Flag = "ToggleZFix", 
   Callback = function(Value)
      flags.autoZ = Value
      if Value then startLoop(Enum.KeyCode.Z, "autoZ") end
   end,
})

AutoTab:CreateToggle({
   Name = "⚡ Auto X",
   CurrentValue = false,
   Flag = "ToggleXFix",
   Callback = function(Value)
      flags.autoX = Value
      if Value then startLoop(Enum.KeyCode.X, "autoX") end
   end,
})

AutoTab:CreateToggle({
   Name = "🟢 Auto C",
   CurrentValue = false,
   Flag = "ToggleCAuto",
   Callback = function(Value)
      flags.autoC = Value
      if Value then startLoop(Enum.KeyCode.C, "autoC") end
   end,
})

AutoTab:CreateToggle({
   Name = "🔵 Auto D",
   CurrentValue = false,
   Flag = "ToggleDAuto",
   Callback = function(Value)
      flags.autoD = Value
      if Value then startLoop(Enum.KeyCode.D, "autoD") end
   end,
})

-- TAB TITAN FISCH
local FischTab = Window:CreateTab("Titan Fisch", 7072742186)

FischTab:CreateSection("🎣 Câu cá & Tự động")

FischTab:CreateToggle({
   Name = "🎣 Auto Thả Cần (Full Power)",
   CurrentValue = false,
   Flag = "AutoCastFix",
   Callback = function(Value)
      flags.autoCast = Value
      if Value then
         task.spawn(function()
            while flags.autoCast do
               local char = player.Character
               if char and char:FindFirstChildOfClass("Tool") then
                  local mouse = player:GetMouse()
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 0)
                  task.wait(0.5 + math.random(-5, 5) / 100)
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 0)
                  task.wait(0.5 + math.random(-10, 10) / 100)
               end
               task.wait(0.2)
            end
         end)
      end
   end,
})

FischTab:CreateToggle({
   Name = "🧠 Smart Auto Slot 1",
   CurrentValue = false,
   Flag = "SmartSlot1",
   Callback = function(Value)
      flags.autoSlot1Smart = Value
      if Value then
         task.spawn(function()
            while flags.autoSlot1Smart do
               local char = player.Character
               if not (char and char:FindFirstChildOfClass("Tool")) then
                  vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                  task.wait(0.05)
                  vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
               end
               task.wait(0.5)
            end
         end)
      end
   end,
})

FischTab:CreateSection("💰 Kinh tế")

FischTab:CreateToggle({
   Name = "💵 Auto Sell (Bán tất cả)",
   CurrentValue = false,
   Flag = "ToggleAutoSell",
   Callback = function(Value)
      flags.autoSell = Value
      if Value then
         task.spawn(function()
            while flags.autoSell do
               -- Lệnh bán bạn yêu cầu (đã thêm tên Remote mặc định của Fisch)
               local args = {{}}
               pcall(function()
                  game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("Functions"):WaitForChild("SellEverything"):InvokeServer(unpack(args))
               end)
               task.wait(5) -- Bán mỗi 5 giây để tránh bị kick/lag
            end
         end)
      end
   end,
})

-- Nút bán nhanh thủ công
FischTab:CreateButton({
   Name = "⚡ Bán ngay lập tức",
   Callback = function()
      local args = {{}}
      game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("Functions"):WaitForChild("SellEverything"):InvokeServer(unpack(args))
      Rayfield:Notify({Title = "Hệ thống", Content = "Đã gửi lệnh bán!", Duration = 2})
   end,
})

-- QUAN TRỌNG: Load Config để tự bật các tính năng khi mở Script
Rayfield:LoadConfiguration()

Rayfield:Notify({
   Title = "Thành công!",
   Content = "Đã tích hợp Auto Sell & Load Config.",
   Duration = 5,
})
