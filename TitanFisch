local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Titan Fisch 235",
   LoadingTitle = "Đang tải cấu hình...",
   LoadingSubtitle = "JICEO",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "ReyFile_Configs",
      FileName = "MainConfig"
   },
   KeySystem = false
})

local player = game.Players.LocalPlayer
local flags = { autoSell = false }

-- Cấu hình tọa độ
local sellPosition = CFrame.new(170.08, 23.4, 72.58)
local lastFishingPos = nil -- Biến lưu vị trí cũ

-- Hàm Dịch Chuyển Tức Thời (Instant TP)
local function instantTeleport(targetCFrame)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = targetCFrame
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0) -- Dừng quán tính
    end
end

local FischTab = Window:CreateTab("Titan Fisch", 7072742186)
FischTab:CreateSection("💰 Auto TP Sell & Return")

FischTab:CreateToggle({
   Name = "🔄 Auto Sell & Quay lại chỗ cũ",
   CurrentValue = false,
   Flag = "ToggleAutoSellReturn",
   Callback = function(Value)
      flags.autoSell = Value
      if Value then
         task.spawn(function()
            while flags.autoSell do
               local char = player.Character
               if char and char:FindFirstChild("HumanoidRootPart") then
                  -- 1. Ghi nhớ vị trí đang đứng câu
                  lastFishingPos = char.HumanoidRootPart.CFrame
                  
                  -- 2. TP tức thời đến nơi bán
                  instantTeleport(sellPosition)
                  task.wait(0.5) -- Đợi server nhận vị trí tại shop
                  
                  -- 3. Gửi lệnh bán
                  local args = {{}}
                  pcall(function()
                     game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("Functions"):WaitForChild("SellEverything"):InvokeServer(unpack(args))
                  end)
                  
                  Rayfield:Notify({Title = "Hệ thống", Content = "Đã bán xong! Đang quay lại...", Duration = 2})
                  task.wait(0.5) -- Đợi 1 chút sau khi bán
                  
                  -- 4. TP quay lại vị trí cũ
                  if lastFishingPos then
                     instantTeleport(lastFishingPos)
                  end
               end
               
               -- Nghỉ 15 giây trước khi lặp lại (an toàn cho account)
               task.wait(15)
            end
         end)
      end
   end,
})

FischTab:CreateSection("📍 Tùy chỉnh nhanh")
FischTab:CreateButton({
   Name = "🏠 TP về vị trí câu vừa lưu",
   Callback = function()
      if lastFishingPos then
         instantTeleport(lastFishingPos)
      else
         Rayfield:Notify({Title = "Lỗi", Content = "Chưa có vị trí cũ được lưu!", Duration = 3})
      end
   end,
})

-- QUAN TRỌNG: Tự động Load Config
Rayfield:LoadConfiguration()

Rayfield:Notify({
   Title = "Hoàn tất!",
   Content = "Script đã sẵn sàng: Tự động bán và quay lại chỗ cũ.",
   Duration = 5,
})
