local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "ReyFile | AUTO TP & SELL",
   LoadingTitle = "Đang tải cấu hình...",
   LoadingSubtitle = "by Gemini (Safe TP Mode)",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "ReyFile_Configs",
      FileName = "MainConfig"
   },
   KeySystem = false
})

local vim = game:GetService("VirtualInputManager")
local player = game.Players.LocalPlayer
local flags = {
    autoZ = false, autoX = false, autoC = false, autoD = false,
    autoCast = false, autoSlot1Smart = false, autoSell = false
}

-- Hàm dịch chuyển an toàn
local function teleportTo(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

-- Tọa độ bán cá bạn yêu cầu
local sellPosition = Vector3.new(170.08, 23.4, 72.58)

-- [TAB AUTO PHÍM - GIỮ NGUYÊN NHƯ CŨ]
local AutoTab = Window:CreateTab("Auto Phím", 4483345998)
local function startLoop(keyCode, flagName)
    task.spawn(function()
        while flags[flagName] do
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(math.random(3, 7) / 100)
            vim:SendKeyEvent(false, keyCode, false, game)
            task.wait(math.random(10, 18) / 100)
        end
    end)
end
AutoTab:CreateToggle({Name = "🚀 Auto Z", CurrentValue = false, Flag = "ToggleZFix", Callback = function(V) flags.autoZ = V if V then startLoop(Enum.KeyCode.Z, "autoZ") end end})
AutoTab:CreateToggle({Name = "⚡ Auto X", CurrentValue = false, Flag = "ToggleXFix", Callback = function(V) flags.autoX = V if V then startLoop(Enum.KeyCode.X, "autoX") end end})
AutoTab:CreateToggle({Name = "🟢 Auto C", CurrentValue = false, Flag = "ToggleCAuto", Callback = function(V) flags.autoC = V if V then startLoop(Enum.KeyCode.C, "autoC") end end})
AutoTab:CreateToggle({Name = "🔵 Auto D", CurrentValue = false, Flag = "ToggleDAuto", Callback = function(V) flags.autoD = V if V then startLoop(Enum.KeyCode.D, "autoD") end end})

-- [TAB TITAN FISCH - CÓ AUTO TP SELL]
local FischTab = Window:CreateTab("Titan Fisch", 7072742186)

FischTab:CreateSection("🎣 Auto Farm")

FischTab:CreateToggle({
   Name = "🎣 Auto Thả Cần",
   CurrentValue = false,
   Flag = "AutoCastFix",
   Callback = function(Value)
      flags.autoCast = Value
      if Value then
         task.spawn(function()
            while flags.autoCast do
               local char = player.Character
               if char and char:FindFirstChildOfClass("Tool") then
                  local mouse = player:GetMouse()
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 0)
                  task.wait(1)
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 0)
               end
               task.wait(0.5)
            end
         end)
      end
   end,
})

FischTab:CreateSection("💰 Kinh tế (TP to Sell)")

FischTab:CreateToggle({
   Name = "💵 Auto TP & Sell (Tự TP đến nơi bán)",
   CurrentValue = false,
   Flag = "ToggleAutoSell",
   Callback = function(Value)
      flags.autoSell = Value
      if Value then
         task.spawn(function()
            while flags.autoSell do
               -- Bước 1: Bay đến tọa độ bán cá
               teleportTo(sellPosition)
               task.wait(0.5) -- Đợi 0.5s để server nhận diện vị trí mới
               
               -- Bước 2: Thực hiện lệnh bán
               local args = {{}}
               pcall(function()
                  game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("Functions"):WaitForChild("SellEverything"):InvokeServer(unpack(args))
               end)
               
               Rayfield:Notify({Title = "Auto Sell", Content = "Đã TP và bán cá thành công!", Duration = 2})
               
               task.wait(10) -- Nghỉ 10 giây mỗi lần bán để tránh bị phát hiện TP liên tục
            end
         end)
      end
   end,
})

FischTab:CreateButton({
   Name = "📍 TP đến nơi bán ngay lập tức",
   Callback = function()
      teleportTo(sellPosition)
   end,
})

-- TỰ ĐỘNG LOAD CONFIG
Rayfield:LoadConfiguration()

Rayfield:Notify({
   Title = "Hệ thống Ready!",
   Content = "Auto TP & Sell đã được thiết lập tại 170.08, 23.4, 72.58",
   Duration = 5,
})
