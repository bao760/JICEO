local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "ReyFile | FULL FIX ZXCD + AUTO TP",
   LoadingTitle = "Đang chuẩn bị hệ thống...",
   LoadingSubtitle = "by Gemini (Perfect TP Return)",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "ReyFile_Configs",
      FileName = "MainConfig"
   },
   KeySystem = false
})

local vim = game:GetService("VirtualInputManager")
local player = game.Players.LocalPlayer
local flags = {
    autoZ = false, autoX = false, autoC = false, autoD = false,
    autoCast = false, autoSell = false
}

-- Cấu hình tọa độ
local sellPosition = Vector3.new(170.08, 23.4, 72.58)
local farmPosition = nil 

-- Hàm Dịch Chuyển Tức Thời (Xử lý cả Vector3 và CFrame)
local function instantTP(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local target = (typeof(pos) == "Vector3" and CFrame.new(pos) or pos)
        char.HumanoidRootPart.CFrame = target
        -- Xóa mọi lực quán tính để đứng im ngay lập tức
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end

-- [TAB AUTO PHÍM]
local AutoTab = Window:CreateTab("Auto Phím", 4483345998)
AutoTab:CreateSection("🔥 Spam phím full tốc độ")

local function startLoop(keyCode, flagName)
    task.spawn(function()
        while flags[flagName] do
            vim:SendKeyEvent(true, keyCode, false, game)
            task.wait(math.random(3, 7) / 100)
            vim:SendKeyEvent(false, keyCode, false, game)
            task.wait(math.random(10, 18) / 100)
        end
    end)
end

AutoTab:CreateToggle({Name = "🚀 Auto Z", CurrentValue = false, Flag = "TZ", Callback = function(V) flags.autoZ = V if V then startLoop(Enum.KeyCode.Z, "autoZ") end end})
AutoTab:CreateToggle({Name = "⚡ Auto X", CurrentValue = false, Flag = "TX", Callback = function(V) flags.autoX = V if V then startLoop(Enum.KeyCode.X, "autoX") end end})
AutoTab:CreateToggle({Name = "🟢 Auto C", CurrentValue = false, Flag = "TC", Callback = function(V) flags.autoC = V if V then startLoop(Enum.KeyCode.C, "autoC") end end})
AutoTab:CreateToggle({Name = "🔵 Auto D", CurrentValue = false, Flag = "TD", Callback = function(V) flags.autoD = V if V then startLoop(Enum.KeyCode.D, "autoD") end end})

-- [TAB TITAN FISCH]
local FischTab = Window:CreateTab("Titan Fisch", 7072742186)

FischTab:CreateSection("📍 BƯỚC 1: THIẾT LẬP")

FischTab:CreateButton({
   Name = "🚩 SET TỌA ĐỘ FARM TẠI ĐÂY",
   Callback = function()
      local char = player.Character
      if char and char:FindFirstChild("HumanoidRootPart") then
          farmPosition = char.HumanoidRootPart.CFrame
          Rayfield:Notify({Title = "Thành công", Content = "Đã lưu điểm Farm. Giờ bạn có thể bật Auto Sell!", Duration = 3})
      end
   end,
})

FischTab:CreateSection("🎣 BƯỚC 2: AUTO FARM")

FischTab:CreateToggle({
   Name = "🎣 Auto Thả Cần",
   CurrentValue = false,
   Flag = "AutoCastFix",
   Callback = function(Value)
      flags.autoCast = Value
      if Value then
         task.spawn(function()
            while flags.autoCast do
               local char = player.Character
               if char and char:FindFirstChildOfClass("Tool") then
                  local mouse = player:GetMouse()
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 0)
                  task.wait(1)
                  vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 0)
               end
               task.wait(0.5)
            end
         end)
      end
   end,
})

FischTab:CreateSection("💰 BƯỚC 3: KINH TẾ")

FischTab:CreateToggle({
   Name = "💵 Auto TP Sell & Return (Fixed)",
   CurrentValue = false,
   Flag = "ToggleAutoSellReturn",
   Callback = function(Value)
      flags.autoSell = Value
      if Value then
         task.spawn(function()
            while flags.autoSell do
               if not farmPosition then
                  Rayfield:Notify({Title = "LỖI", Content = "Hãy nhấn nút SET TỌA ĐỘ FARM trước!", Duration = 5})
                  flags.autoSell = false
                  break
               end
               
               -- 1. TP ĐI BÁN
               instantTP(sellPosition)
               task.wait(0.8) -- Đợi server nhận vị trí tại shop
               
               -- 2. GỬI LỆNH BÁN
               local args = {{}}
               pcall(function()
                  game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("Functions"):WaitForChild("SellEverything"):InvokeServer(unpack(args))
               end)
               
               -- 3. ĐỢI NGẮN RỒI TP VỀ NGAY
               task.wait(0.5) 
               instantTP(farmPosition)
               
               Rayfield:Notify({Title = "Hệ thống", Content = "Đã bán và quay về chỗ câu!", Duration = 2})
               
               -- Nghỉ 20 giây để tránh bị kick do TP liên tục
               task.wait(20) 
            end
         end)
      end
   end,
})

